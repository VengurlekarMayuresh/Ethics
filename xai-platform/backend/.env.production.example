# XAI Platform Production Environment Variables

# Database
MONGO_URL=mongodb://mongo:27017/xai_platform
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_password_here

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO/S3 Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xai-models
MINIO_REGION=us-east-1

# MinIO Server-Side Encryption (optional)
# MINIO_SSE_ENABLED=true
# MINIO_SSE_MASTER_KEY=your-base64-encoded-32-byte-key

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI for NLG (optional)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Rate Limiting
RATE_LIMIT_ANONYMOUS=60
RATE_LIMIT_AUTH=300
RATE_LIMIT_API_KEY=500

# Encryption (for PII at rest) - generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-base64-encryption-key-here

# Logging
LOG_LEVEL=INFO

# Pickle compatibility for custom sklearn transformers/classes
# Comma-separated importable modules that define classes used in pickled models.
PICKLE_CLASS_MODULES=app.custom.feature_engineer
